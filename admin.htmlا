<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin — شغل مخك</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#07071a;--surface:#0d0d22;--card:#12122a;--card2:#181836;
  --border:rgba(255,255,255,.07);--glow-border:rgba(139,92,246,.2);
  --accent:#8b5cf6;--a2:#a78bfa;--gold:#fbbf24;--g2:#f59e0b;
  --green:#10b981;--red:#ef4444;--blue:#60a5fa;
  --text:#f4f3ff;--t2:rgba(244,243,255,.45);--t3:rgba(244,243,255,.2);
  --grad:linear-gradient(135deg,#8b5cf6,#a78bfa);
  --grad-gold:linear-gradient(135deg,#fbbf24,#f59e0b);
  --grad-green:linear-gradient(135deg,#10b981,#059669);
  --glow:rgba(139,92,246,.25);
}
html,body{font-family:'Tajawal',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
body::before{content:'';position:fixed;inset:0;pointer-events:none;background:radial-gradient(ellipse 80% 50% at 50% -10%,rgba(139,92,246,.15) 0%,transparent 70%)}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:var(--accent);border-radius:10px}

.app{position:relative;z-index:1;max-width:1440px;margin:0 auto;padding:16px}

/* ── TOPBAR ── */
.topbar{display:flex;justify-content:space-between;align-items:center;padding:14px 22px;margin-bottom:20px;background:rgba(13,13,34,.9);border:1px solid var(--glow-border);border-radius:18px;backdrop-filter:blur(20px);box-shadow:0 4px 30px rgba(0,0,0,.4)}
.logo{display:flex;align-items:center;gap:11px}
.logo-icon{width:40px;height:40px;border-radius:12px;background:var(--grad);display:flex;align-items:center;justify-content:center;font-size:20px;box-shadow:0 0 20px var(--glow)}
.logo-name{font-size:18px;font-weight:900}
.logo-name em{font-style:normal;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.logo-sub{font-size:9px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.07em}
.topbar-right{display:flex;gap:8px;align-items:center}

/* ── STATS ── */
.stats-row{display:grid;grid-template-columns:repeat(8,1fr);gap:10px;margin-bottom:20px}
@media(max-width:1200px){.stats-row{grid-template-columns:repeat(4,1fr)}}
@media(max-width:700px){.stats-row{grid-template-columns:repeat(2,1fr)}}
.sc{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px 16px;transition:.2s;cursor:default}
.sc:hover{border-color:var(--glow-border);transform:translateY(-1px)}
.sc-icon{font-size:18px;margin-bottom:7px;display:block}
.sc-num{font-size:24px;font-weight:900;display:block;line-height:1}
.sc-lbl{font-size:9px;font-weight:700;color:var(--t2);margin-top:3px;text-transform:uppercase;letter-spacing:.05em}

/* ── MAIN GRID ── */
.main-grid{display:grid;grid-template-columns:420px 1fr;gap:16px}
@media(max-width:1100px){.main-grid{grid-template-columns:1fr}}

/* ── PANEL ── */
.panel{background:var(--card);border:1px solid var(--border);border-radius:18px;overflow:hidden}
.ph{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.02)}
.ph-title{font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:.1em;color:var(--t2);display:flex;align-items:center;gap:7px}
.ph-title i{color:var(--accent)}
.pb{padding:16px}

/* ── TABS ── */
.tab-bar{display:flex;gap:3px;background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:3px;margin-bottom:16px}
.tab{flex:1;padding:8px 4px;border:none;background:transparent;color:var(--t2);font-family:'Tajawal',sans-serif;font-weight:900;font-size:10px;cursor:pointer;border-radius:10px;transition:.2s;display:flex;align-items:center;justify-content:center;gap:4px;white-space:nowrap}
.tab:hover{color:var(--text);background:rgba(255,255,255,.04)}
.tab.active{background:var(--grad);color:#fff;box-shadow:0 3px 12px var(--glow)}

/* ── FORM ── */
.fg{margin-bottom:12px}
.fl{display:block;font-size:10px;font-weight:900;color:var(--t2);margin-bottom:5px;text-transform:uppercase;letter-spacing:.07em}
.fc{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:11px;padding:10px 14px;color:var(--text);font-family:'Tajawal',sans-serif;font-size:13px;font-weight:700;outline:none;text-align:right;transition:border-color .2s,box-shadow .2s}
.fc:focus{border-color:rgba(139,92,246,.5);box-shadow:0 0 0 3px rgba(139,92,246,.1)}
.fc option{background:#12122a}
textarea.fc{min-height:70px;resize:vertical;line-height:1.6}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}

/* ── OPTIONS ── */
.opts-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:3px}
.opt-item{position:relative}
.opt-letter{position:absolute;top:-7px;right:9px;z-index:2;font-size:9px;font-weight:900;padding:1px 6px;border-radius:6px;background:var(--card2);color:var(--t2);border:1px solid var(--border);font-family:'JetBrains Mono',monospace}
.opt-in{width:100%;background:var(--surface);border:2px solid var(--border);border-radius:10px;padding:9px 12px;color:var(--text);font-family:'Tajawal',sans-serif;font-size:12px;font-weight:700;outline:none;text-align:right;transition:.2s}
.opt-in:focus{border-color:rgba(96,165,250,.5)}
.opt-in.ok{border-color:var(--green)!important;background:rgba(16,185,129,.07)}
.cr{display:flex;align-items:center;gap:5px;margin-top:4px;cursor:pointer}
.cr input[type=radio]{accent-color:var(--green);width:13px;height:13px;cursor:pointer}
.cr span{font-size:10px;font-weight:700;color:var(--green)}

/* ── BUTTONS ── */
.btn{border:none;border-radius:11px;padding:10px 16px;font-family:'Tajawal',sans-serif;font-weight:900;font-size:13px;cursor:pointer;transition:.15s;display:inline-flex;align-items:center;justify-content:center;gap:6px;white-space:nowrap}
.btn:active{transform:scale(.95)}
.btn:disabled{opacity:.4;cursor:not-allowed;transform:none}
.btn-primary{background:var(--grad);color:#fff;width:100%;font-size:14px;padding:13px;box-shadow:0 5px 16px var(--glow);border-bottom:3px solid rgba(0,0,0,.2)}
.btn-primary:active:not(:disabled){border-bottom-width:1px}
.btn-green{background:var(--grad-green);color:#fff;width:100%;font-size:14px;padding:13px;box-shadow:0 5px 16px rgba(16,185,129,.25);border-bottom:3px solid rgba(0,0,0,.2)}
.btn-green:active:not(:disabled){border-bottom-width:1px}
.btn-gold{background:var(--grad-gold);color:#000;border-bottom:3px solid rgba(0,0,0,.15)}
.btn-gold:active:not(:disabled){border-bottom-width:1px}
.btn-ai{background:linear-gradient(135deg,#1e0a3c,#2e1060);color:var(--a2);border:1px solid rgba(139,92,246,.3);width:100%;font-size:14px;padding:13px;box-shadow:0 5px 16px rgba(139,92,246,.2);position:relative;overflow:hidden}
.btn-ai::after{content:'';position:absolute;inset:0;background:var(--grad);opacity:0;transition:.3s}
.btn-ai:hover:not(:disabled)::after{opacity:.07}
.ai-spark{position:absolute;width:60px;height:60px;background:var(--accent);border-radius:50%;filter:blur(22px);opacity:.18;top:-10px;left:50%;transform:translateX(-50%);animation:spark 2.5s ease-in-out infinite}
@keyframes spark{0%,100%{opacity:.12;transform:translateX(-50%) scale(1)}50%{opacity:.28;transform:translateX(-50%) scale(1.5)}}
.btn-ghost{background:rgba(255,255,255,.05);color:var(--t2);border:1px solid var(--border)}
.btn-ghost:hover{background:rgba(255,255,255,.09);color:var(--text)}
.btn-red{background:rgba(239,68,68,.1);color:var(--red);border:1px solid rgba(239,68,68,.2)}
.btn-red:hover{background:rgba(239,68,68,.18)}
.btn-sm{padding:7px 12px;font-size:11px;border-radius:9px}
.btn-icon{width:33px;height:33px;padding:0;border-radius:9px;background:rgba(255,255,255,.04);color:var(--t2);border:1px solid var(--border)}
.btn-icon:hover{background:rgba(239,68,68,.1);color:var(--red);border-color:rgba(239,68,68,.2)}

/* ── STATUS ── */
.sbadge{display:flex;align-items:center;gap:7px;padding:7px 13px;background:var(--card2);border:1px solid var(--border);border-radius:11px;font-size:11px;font-weight:700;color:var(--t2)}
.sdot{width:7px;height:7px;border-radius:50%;background:var(--red);flex-shrink:0;transition:.4s}
.sdot.on{background:var(--green);box-shadow:0 0 8px var(--green)}

/* ── AI KEY ── */
.key-wrap{position:relative}
.key-in{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:11px;padding:10px 40px 10px 14px;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:12px;outline:none;text-align:left;direction:ltr;transition:border-color .2s}
.key-in:focus{border-color:rgba(139,92,246,.5)}
.key-eye{position:absolute;left:11px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--t2);cursor:pointer;font-size:13px}

/* ── PROGRESS ── */
.prog-outer{background:rgba(255,255,255,.06);border-radius:8px;overflow:hidden;height:5px;margin-top:8px}
.prog-inner{height:100%;background:var(--grad);border-radius:8px;transition:width .3s ease;width:0%}
.prog-inner.green{background:var(--grad-green)}
.prog-row{display:flex;justify-content:space-between;font-size:10px;font-weight:900;color:var(--t2);margin-top:5px}

/* ── AI PREVIEW ── */
.ai-prev{background:var(--surface);border:1px solid rgba(139,92,246,.2);border-radius:13px;padding:13px;margin-top:12px;display:none}
.ai-prev.show{display:block;animation:fadeUp .3s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.prev-q{font-size:12px;font-weight:700;color:var(--text);margin-bottom:8px;line-height:1.5}
.prev-opts{display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-bottom:8px}
.prev-opt{font-size:10px;font-weight:700;padding:5px 9px;border-radius:8px;background:rgba(255,255,255,.04);color:var(--t2)}
.prev-opt.c{background:rgba(16,185,129,.1);color:var(--green);border:1px solid rgba(16,185,129,.2)}
.prev-exp{font-size:10px;font-weight:700;color:var(--t2);padding:6px 9px;background:rgba(251,191,36,.05);border-radius:8px;border-right:2px solid var(--gold);line-height:1.5}
.prev-nav{display:flex;justify-content:space-between;align-items:center;margin-top:10px}
.prev-ctr{font-size:10px;font-weight:900;color:var(--t2);font-family:'JetBrains Mono',monospace}
.divider{height:1px;background:var(--border);margin:11px 0}

/* ── DROP ZONE ── */
.drop-z{border:2px dashed rgba(139,92,246,.25);border-radius:13px;padding:24px 18px;text-align:center;cursor:pointer;transition:.25s;position:relative;background:rgba(139,92,246,.03)}
.drop-z:hover,.drop-z.over{border-color:var(--accent);background:rgba(139,92,246,.07);box-shadow:0 0 0 4px rgba(139,92,246,.08)}
.drop-z input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.drop-icon{font-size:28px;display:block;margin-bottom:8px;opacity:.6}
.drop-t{font-size:13px;font-weight:900;margin-bottom:3px}
.drop-s{font-size:11px;font-weight:700;color:var(--t2)}
.fbadge{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.2);border-radius:8px;font-size:10px;font-weight:900;color:var(--green);margin-top:8px}

/* ── JSON BLOCK ── */
.jblk{background:var(--surface);border:1px solid var(--border);border-radius:11px;padding:11px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--t2);line-height:1.7;overflow:auto;max-height:150px;white-space:pre-wrap;direction:ltr;text-align:left}
.slbl{font-size:9px;font-weight:900;color:var(--t3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:7px;display:flex;align-items:center;gap:5px}
.slbl::after{content:'';flex:1;height:1px;background:var(--border)}

/* ── DISTRIBUTE BOX ── */
.dist-box{background:linear-gradient(135deg,rgba(16,185,129,.08),rgba(5,150,105,.04));border:1px solid rgba(16,185,129,.2);border-radius:14px;padding:16px;margin-bottom:14px}
.dist-title{font-size:12px;font-weight:900;color:var(--green);margin-bottom:10px;display:flex;align-items:center;gap:6px}
.dist-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:6px;margin-bottom:12px}
.dist-item{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:10px;padding:8px 10px;display:flex;justify-content:space-between;align-items:center}
.dist-cat{font-size:11px;font-weight:700;color:var(--text)}
.dist-num{font-size:12px;font-weight:900;color:var(--green)}

/* ── Q LIST ── */
.list-bar{display:flex;gap:7px;margin-bottom:12px;flex-wrap:wrap}
.s-wrap{flex:1;position:relative;min-width:150px}
.s-icon{position:absolute;top:50%;right:11px;transform:translateY(-50%);color:var(--t3);font-size:11px}
.s-in{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:11px;padding:9px 34px 9px 12px;color:var(--text);font-family:'Tajawal',sans-serif;font-size:12px;font-weight:700;outline:none;text-align:right;transition:border-color .2s}
.s-in:focus{border-color:rgba(139,92,246,.4)}
.fsel{background:var(--surface);border:1px solid var(--border);border-radius:11px;padding:9px 12px;color:var(--text);font-family:'Tajawal',sans-serif;font-size:11px;font-weight:700;outline:none;cursor:pointer}
.fsel option{background:#12122a}

.ql{display:flex;flex-direction:column;gap:6px;max-height:calc(100vh - 280px);overflow-y:auto;padding-left:2px}
.qi{background:var(--card2);border:1px solid var(--border);border-radius:14px;padding:12px 14px;transition:.2s}
.qi:hover{border-color:rgba(139,92,246,.2);background:#1a1a38}
.qi-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:6px}
.qi-txt{font-size:12px;font-weight:700;color:var(--text);flex:1;line-height:1.4}
.qi-chips{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:6px}
.chip{font-size:9px;font-weight:900;padding:2px 8px;border-radius:6px;white-space:nowrap}
.cc{background:rgba(139,92,246,.12);color:var(--a2)}
.cs{background:rgba(96,165,250,.1);color:var(--blue)}
.cn{background:rgba(255,255,255,.05);color:var(--t2);font-family:'JetBrains Mono',monospace}
.qi-opts{display:grid;grid-template-columns:1fr 1fr;gap:3px}
.qo{font-size:10px;font-weight:700;padding:4px 8px;border-radius:7px;background:rgba(255,255,255,.03);color:var(--t2)}
.qo.ok{background:rgba(16,185,129,.08);color:var(--green)}
.qi-exp{font-size:10px;font-weight:700;color:var(--t2);margin-top:5px;padding:5px 8px;background:rgba(251,191,36,.05);border-radius:7px;border-right:2px solid var(--gold);line-height:1.4}
.cpill{background:rgba(139,92,246,.12);color:var(--a2);font-size:10px;font-weight:900;padding:2px 9px;border-radius:20px;border:1px solid rgba(139,92,246,.2)}

/* ── STATE ── */
.state{text-align:center;padding:40px 20px}
.state-e{font-size:36px;display:block;margin-bottom:9px;opacity:.5}
.state-t{font-size:12px;font-weight:700;color:var(--t2)}
.spin{animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── TOAST ── */
#toasts{position:fixed;top:16px;left:50%;transform:translateX(-50%);z-index:9999;display:flex;flex-direction:column;gap:7px;align-items:center;pointer-events:none;min-width:240px}
.t{background:rgba(18,18,42,.95);border:1px solid var(--border);color:var(--text);font-family:'Tajawal',sans-serif;font-size:13px;font-weight:900;padding:11px 20px;border-radius:14px;box-shadow:0 8px 28px rgba(0,0,0,.5);animation:tin .3s cubic-bezier(.34,1.56,.64,1);text-align:center;backdrop-filter:blur(16px)}
.t.ok{border-color:rgba(16,185,129,.3);background:rgba(16,185,129,.08)}
.t.err{border-color:rgba(239,68,68,.3);background:rgba(239,68,68,.08)}
.t.inf{border-color:rgba(139,92,246,.3);background:rgba(139,92,246,.08)}
.t.out{animation:tout .25s ease forwards}
@keyframes tin{from{opacity:0;transform:translateY(-10px) scale(.88)}to{opacity:1;transform:none}}
@keyframes tout{from{opacity:1}to{opacity:0;transform:translateY(-8px) scale(.9)}}

/* ── MODAL ── */
.mwrap{position:fixed;inset:0;background:rgba(0,0,0,.8);backdrop-filter:blur(14px);z-index:8000;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .25s}
.mwrap.show{opacity:1;pointer-events:all}
.mbox{background:var(--card);border:1px solid var(--glow-border);border-radius:20px;padding:24px;max-width:360px;width:100%;transform:scale(.86) translateY(14px);transition:transform .3s cubic-bezier(.34,1.56,.64,1)}
.mwrap.show .mbox{transform:none}
.micon{font-size:40px;text-align:center;margin-bottom:8px}
.mtitle{font-size:18px;font-weight:900;text-align:center;margin-bottom:5px}
.mmsg{font-size:12px;font-weight:700;color:var(--t2);text-align:center;margin-bottom:18px;line-height:1.6}
.mbtns{display:flex;gap:8px}

/* MISC */
.badge-pill{display:inline-flex;align-items:center;gap:5px;padding:4px 11px;border-radius:9px;font-size:10px;font-weight:900}
.badge-ai{background:rgba(139,92,246,.12);color:var(--a2);border:1px solid rgba(139,92,246,.25)}
.badge-green{background:rgba(16,185,129,.1);color:var(--green);border:1px solid rgba(16,185,129,.2)}
.info-box{background:rgba(96,165,250,.05);border:1px solid rgba(96,165,250,.15);border-radius:12px;padding:12px;font-size:11px;font-weight:700;color:var(--t2);line-height:1.7;margin-top:10px}
.info-box b{color:var(--text)}
</style>
</head>
<body>
<div class="app">

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="logo">
      <div class="logo-icon">🧠</div>
      <div><div class="logo-name">شغل <em>مخك</em></div><div class="logo-sub">Admin Panel v3.0</div></div>
    </div>
    <div class="topbar-right">
      <div class="sbadge"><div class="sdot" id="sdot"></div><span id="stxt">جاري الاتصال...</span></div>
      <button class="btn btn-ghost btn-sm" onclick="loadQs()"><i class="fas fa-sync-alt"></i> تحديث</button>
      <button class="btn btn-ghost btn-sm" onclick="exportAll()"><i class="fas fa-download"></i> تصدير</button>
      <button class="btn btn-red btn-sm" onclick="clearAllConfirm()"><i class="fas fa-trash"></i> مسح الكل</button>
    </div>
  </div>

  <!-- STATS -->
  <div class="stats-row">
    <div class="sc"><span class="sc-icon">📚</span><span class="sc-num" id="st0">—</span><div class="sc-lbl">الإجمالي</div></div>
    <div class="sc"><span class="sc-icon">🕌</span><span class="sc-num" id="st1">—</span><div class="sc-lbl">إسلاميات</div></div>
    <div class="sc"><span class="sc-icon">💻</span><span class="sc-num" id="st2">—</span><div class="sc-lbl">تقنية</div></div>
    <div class="sc"><span class="sc-icon">🏺</span><span class="sc-num" id="st3">—</span><div class="sc-lbl">تاريخ مصر</div></div>
    <div class="sc"><span class="sc-icon">🏙️</span><span class="sc-num" id="st4">—</span><div class="sc-lbl">أحياء القاهرة</div></div>
    <div class="sc"><span class="sc-icon">🎵</span><span class="sc-num" id="st5">—</span><div class="sc-lbl">موسيقى وأغاني</div></div>
    <div class="sc"><span class="sc-icon">🎬</span><span class="sc-num" id="st6">—</span><div class="sc-lbl">سينما</div></div>
    <div class="sc"><span class="sc-icon">💬</span><span class="sc-num" id="st7">—</span><div class="sc-lbl">كلمات مصرية</div></div>
  </div>

  <div class="main-grid">

    <!-- ═══ LEFT ═══ -->
    <div style="display:flex;flex-direction:column;gap:14px">
      <div class="tab-bar">
